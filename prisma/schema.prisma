generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  firebase_uid     String?          @unique
  password         String?
  name             String
  email            String           @unique
  avatar           String?
  role_id          String?
  role             Role?            @relation(fields: [role_id], references: [id])
  status           String           @default("ACTIVE")
  is_verified      Boolean          @default(false)
  is_banned        Boolean          @default(false)
  is_deleted       Boolean          @default(false)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  creator_profile  CreatorProfile?
  brand_profile    BrandProfile?
  wallets          Wallet[]
  notifications    Notification[]
  audit_logs       AuditLog[]
  messages         Message[]
  settings         Json?
  kyc_requests     KycRequest[]
  creator_kyc      CreatorKyc?
  brand_kyc        BrandKyc?
  owned_organizations Organization[] @relation("OrganizationOwner")
  organization_members OrganizationMember[]
  organization_invitations_sent OrganizationInvitation[] @relation("InvitationInviter")
  security_setting     SecuritySetting?
  user_sessions        UserSession[]
  security_activities  SecurityActivity[]
  notification_prefs   NotificationPreference?

  @@map("users")
}

model Role {
  id               String           @id @default(uuid())
  name             String           @unique
  description      String?
  users            User[]
  permissions      RolePermission[]

  @@map("roles")
}

model Permission {
  id               String           @id @default(uuid())
  key              String           @unique
  description      String?
  roles            RolePermission[]

  @@map("permissions")
}

model RolePermission {
  role_id          String
  permission_id    String
  role             Role       @relation(fields: [role_id], references: [id])
  permission       Permission @relation(fields: [permission_id], references: [id])

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model CreatorProfile {
  id               String       @id @default(uuid())
  user_id          String       @unique
  user             User         @relation(fields: [user_id], references: [id])
  full_name        String?
  bio              String?
  niche            String?
  followers        Int          @default(0)
  engagement_rate  Float        @default(0.0)
  languages        String[]
  locality         String?
  social_links     Json?
  media_kit        String?
  portfolio        String?
  contact_email    String?
  phone            String?
  photo            String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  applications     Application[]
  conversations    Conversation[]
  disputes         Dispute[]
  escrows          Escrow[]
  deliverables     Deliverable[]
  withdrawals      Withdrawal[]
  ai_matches       AiMatch[]
  organization     Organization?

  @@map("creator_profiles")
}

model BrandProfile {
  id               String       @id @default(uuid())
  user_id          String       @unique
  user             User         @relation(fields: [user_id], references: [id])
  company_name     String
  industry         String?
  website          String?
  description      String?
  logo             String?
  contact_email    String?
  phone            String?
  location         String?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  campaigns        Campaign[]
  conversations    Conversation[]
  disputes         Dispute[]
  escrows          Escrow[]
  organization     Organization?

  @@map("brand_profiles")
}

model Campaign {
  id                   String       @id @default(uuid())
  brand_id             String
  brand                BrandProfile @relation(fields: [brand_id], references: [id])
  title                String
  description          String
  platform             String
  budget               Float
  remaining_budget     Float
  deadline             DateTime
  deliverables         String[]
  status               String       @default("DRAFT") // ACTIVE, DRAFT, PENDING_APPROVAL, FLAGGED, COMPLETED, FROZEN
  locality             String?
  languages            String[]
  created_by_admin_id  String?
  metadata             Json?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  applications     Application[]
  escrows          Escrow[]
  disputes         Dispute[]
  campaignDeliverables Deliverable[]
  ai_matches       AiMatch[]

  @@map("campaigns")
}

model Application {
  id               String       @id @default(uuid())
  creator_id       String
  creator          CreatorProfile @relation(fields: [creator_id], references: [id])
  campaign_id      String
  campaign         Campaign       @relation(fields: [campaign_id], references: [id])
  message          String?
  proposed_price   Float?
  status           String         @default("PENDING") // PENDING, SHORTLISTED, ACCEPTED, REJECTED, COMPLETED
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  deliverables     Deliverable[]

  @@map("applications")
}

model Deliverable {
  id               String         @id @default(uuid())
  campaign_id      String
  campaign         Campaign       @relation(fields: [campaign_id], references: [id])
  application_id   String?
  application      Application?   @relation(fields: [application_id], references: [id])
  creator_id       String
  creator          CreatorProfile @relation(fields: [creator_id], references: [id])
  title            String
  type             String?
  media_url        String?
  file_url         String?
  thumbnail_url    String?
  notes            String?
  revision_notes   String?
  version          Int            @default(1)
  status           String         @default("PENDING") // PENDING, SUBMITTED, REVISION_REQUESTED, APPROVED, REJECTED
  due_date         DateTime?
  submitted_at     DateTime?
  reviewed_at      DateTime?
  auto_release_at  DateTime?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  @@index([campaign_id, status])
  @@index([status, auto_release_at])
  @@map("deliverables")
}

model Wallet {
  id                String       @id @default(uuid())
  user_id           String       @unique
  user              User         @relation(fields: [user_id], references: [id])
  available_balance Float        @default(0.0)
  locked_balance    Float        @default(0.0)
  pending_balance   Float        @default(0.0)
  lifetime_earnings Float        @default(0.0)
  currency          String       @default("INR")
  is_platform       Boolean      @default(false)
  is_frozen         Boolean      @default(false)
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  transactions      WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id             String   @id @default(uuid())
  wallet_id      String
  wallet         Wallet   @relation(fields: [wallet_id], references: [id])
  type           String
  amount         Float
  balance_after  Float?
  reference_type String?
  reference_id   String?
  status         String   @default("COMPLETED")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([wallet_id, created_at])
  @@index([reference_type, reference_id])
  @@map("wallet_transactions")
}

model Escrow {
  id                   String         @id @default(uuid())
  campaign_id          String
  campaign             Campaign       @relation(fields: [campaign_id], references: [id])
  brand_id             String
  brand                BrandProfile   @relation(fields: [brand_id], references: [id])
  creator_id           String
  creator              CreatorProfile @relation(fields: [creator_id], references: [id])
  amount               Float
  platform_fee_percent Float          @default(10.0)
  platform_fee_amount  Float          @default(0.0)
  creator_amount       Float          @default(0.0)
  platform_fee         Float          @default(0.0)
  payment_gateway      String?
  payment_id           String?
  status               String         @default("PENDING")
  locked_at            DateTime?
  funded_at            DateTime?
  created_at           DateTime       @default(now())
  released_at          DateTime?
  refunded_at          DateTime?
  updated_at           DateTime       @updatedAt

  payment_orders       PaymentOrder[]

  @@index([campaign_id, creator_id, brand_id])
  @@index([status])
  @@map("escrows")
}

model Withdrawal {
  id               String         @id @default(uuid())
  creator_id       String
  creator          CreatorProfile @relation(fields: [creator_id], references: [id])
  amount           Float
  status           String         @default("PENDING") // PENDING, APPROVED, REJECTED
  transaction_id   String?        @unique
  requested_at     DateTime       @default(now())
  approved_at      DateTime?
  rejected_at      DateTime?
  rejection_reason String?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  @@index([creator_id, status])
  @@map("withdrawals")
}

model NotificationPreference {
  id               String   @id @default(uuid())
  user_id          String   @unique
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  email_enabled    Boolean  @default(true)
  push_enabled     Boolean  @default(true)
  payment_alerts   Boolean  @default(true)
  campaign_alerts  Boolean  @default(true)
  marketing_emails Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("notification_preferences")
}

model Conversation {
  id               String         @id @default(uuid())
  creator_id       String
  creator          CreatorProfile @relation(fields: [creator_id], references: [id])
  brand_id         String
  brand            BrandProfile   @relation(fields: [brand_id], references: [id])
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  messages         Message[]

  @@map("conversations")
}

model Message {
  id               String         @id @default(uuid())
  conversation_id  String
  conversation     Conversation   @relation(fields: [conversation_id], references: [id])
  sender_id        String
  sender           User           @relation(fields: [sender_id], references: [id])
  message          String
  type             String         @default("text")
  file_url         String?
  file_name        String?
  file_size        String?
  created_at       DateTime       @default(now())
  read_at          DateTime?

  @@map("messages")
}

model Notification {
  id               String         @id @default(uuid())
  user_id          String
  user             User           @relation(fields: [user_id], references: [id])
  title            String
  body             String
  type             String         @default("SYSTEM")
  entity_type      String?
  entity_id        String?
  metadata         Json?
  is_read          Boolean        @default(false)
  created_at       DateTime       @default(now())

  @@index([user_id, is_read])
  @@index([user_id, created_at])
  @@map("notifications")
}

model Dispute {
  id               String         @id @default(uuid())
  campaign_id      String
  campaign         Campaign       @relation(fields: [campaign_id], references: [id])
  creator_id       String
  creator          CreatorProfile @relation(fields: [creator_id], references: [id])
  brand_id         String
  brand            BrandProfile   @relation(fields: [brand_id], references: [id])
  reason           String
  raised_by        String         @default("brand") // brand, creator
  status           String         @default("OPEN") // OPEN, IN_REVIEW, RESOLVED, REFUNDED
  resolution_notes String?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt

  @@index([campaign_id, creator_id, status])
  @@map("disputes")
}

model PaymentOrder {
  id                  String   @id @default(uuid())
  user_id             String
  escrow_id           String?
  escrow              Escrow?  @relation(fields: [escrow_id], references: [id])
  purpose             String   @default("WALLET_TOPUP")
  razorpay_order_id   String   @unique
  razorpay_payment_id String?
  amount              Float
  currency            String   @default("INR")
  status              String   @default("CREATED")
  metadata            Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@index([user_id, status])
  @@index([escrow_id])
  @@map("payment_orders")
}

model AuditLog {
  id               String         @id @default(uuid())
  admin_id         String
  admin            User           @relation(fields: [admin_id], references: [id])
  action           String
  entity           String
  entity_id        String
  metadata         Json?
  created_at       DateTime       @default(now())

  @@map("audit_logs")
}

model PlatformSettings {
  id                   String   @id @default("default")
  ai_matching_enabled  Boolean  @default(true)
  platform_fee_percent Float    @default(10)
  updated_at           DateTime @updatedAt
  updated_by           String?

  @@map("platform_settings")
}

model AiMatch {
  id           String         @id @default(uuid())
  campaign_id  String
  creator_id   String
  match_score  Int
  reasons      String[]
  status       String         @default("active") // active, removed, forced
  matched_at   DateTime       @default(now())
  campaign     Campaign       @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  creator      CreatorProfile @relation(fields: [creator_id], references: [id], onDelete: Cascade)

  @@unique([campaign_id, creator_id])
  @@map("ai_matches")
}

model RevokedToken {
  id         String   @id @default(uuid())
  jti        String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("revoked_tokens")
}

model KycRequest {
  id           String      @id @default(uuid())
  user_id      String
  user         User        @relation(fields: [user_id], references: [id])
  user_type    String
  status       String      @default("PENDING")
  submitted_at DateTime    @default(now())
  reviewed_at  DateTime?
  reviewed_by  String?
  remarks      String?
  creator_kyc  CreatorKyc?
  brand_kyc    BrandKyc?

  @@index([user_id])
  @@index([status])
  @@map("kyc_requests")
}

model CreatorKyc {
  id                    String      @id @default(uuid())
  user_id               String      @unique
  user                  User        @relation(fields: [user_id], references: [id])
  kyc_request_id        String?     @unique
  kyc_request           KycRequest? @relation(fields: [kyc_request_id], references: [id])
  mobile_number         String?
  mobile_verified       Boolean     @default(false)
  email_verified        Boolean     @default(false)
  instagram_handle      String?
  youtube_handle        String?
  tiktok_handle         String?
  instagram_profile_url String?
  selfie_url            String?
  followers_count       Int         @default(0)
  engagement_rate       Float       @default(0)
  verification_status   String      @default("UNVERIFIED")
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt

  @@map("creator_kyc")
}

model BrandKyc {
  id                      String      @id @default(uuid())
  user_id                   String      @unique
  user                      User        @relation(fields: [user_id], references: [id])
  kyc_request_id            String?     @unique
  kyc_request               KycRequest? @relation(fields: [kyc_request_id], references: [id])
  company_name              String?
  gst_number                String?
  website                   String?
  business_email            String?
  business_email_verified   Boolean     @default(false)
  linkedin_url              String?
  logo_url                  String?
  business_address          String?
  verification_status       String      @default("UNVERIFIED")
  created_at                DateTime    @default(now())
  updated_at                DateTime    @updatedAt

  @@map("brand_kyc")
}

model Organization {
  id                String   @id @default(uuid())
  type              String   // BRAND | CREATOR
  name              String
  owner_user_id     String
  owner             User     @relation("OrganizationOwner", fields: [owner_user_id], references: [id])
  brand_profile_id  String?  @unique
  brand_profile     BrandProfile? @relation(fields: [brand_profile_id], references: [id])
  creator_profile_id String? @unique
  creator_profile   CreatorProfile? @relation(fields: [creator_profile_id], references: [id])
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  members           OrganizationMember[]
  invitations       OrganizationInvitation[]

  @@index([type, owner_user_id])
  @@map("organizations")
}

model OrganizationMember {
  id              String   @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  user_id         String
  user            User     @relation(fields: [user_id], references: [id])
  role            String   // OWNER, CAMPAIGN_MANAGER, FINANCE_MANAGER, VIEWER, MANAGER, EDITOR
  status          String   @default("ACTIVE") // ACTIVE, REMOVED
  invited_by_id   String?
  last_active_at  DateTime?
  joined_at       DateTime @default(now())
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([organization_id, user_id])
  @@index([user_id, status])
  @@map("organization_members")
}

model OrganizationInvitation {
  id              String   @id @default(uuid())
  organization_id String
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  email           String
  role            String
  token           String   @unique @default(uuid())
  invited_by_id   String
  invited_by      User     @relation("InvitationInviter", fields: [invited_by_id], references: [id])
  status          String   @default("PENDING") // PENDING, ACCEPTED, REVOKED, EXPIRED (legacy: CANCELLED)
  expires_at      DateTime
  accepted_at     DateTime?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([email, status])
  @@index([token])
  @@map("organization_invitations")
}

model SecuritySetting {
  id                   String    @id @default(uuid())
  user_id              String    @unique
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  two_factor_enabled   Boolean   @default(false)
  two_factor_type      String?   // SMS
  phone_number         String?
  mfa_enrollment_id    String?
  last_password_change DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  @@map("security_settings")
}

model UserSession {
  id            String   @id @default(uuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  session_token String?  @unique
  device_name   String?
  browser       String?
  ip_address    String?
  location      String?
  is_active     Boolean  @default(true)
  last_active   DateTime @default(now())
  created_at    DateTime @default(now())

  @@index([user_id, is_active])
  @@map("user_sessions")
}

model SecurityActivity {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type       String   // NEW_LOGIN, PASSWORD_CHANGED, 2FA_ENABLED, 2FA_DISABLED, SESSION_REMOVED, LOGOUT_ALL
  device     String?
  browser    String?
  ip_address String?
  location   String?
  metadata   Json?
  created_at DateTime @default(now())

  @@index([user_id, created_at])
  @@map("security_activities")
}
