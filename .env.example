# ─── Neon PostgreSQL (production + Vercel) ───────────────────────────────────
# Neon Console → your project → Connection string
# Use the NON-pooler host for migrations (no "-pooler" in hostname).
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Local PostgreSQL (optional, for dev only) ───────────────────────────────
# DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/viralbridgge?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# Firebase Admin SDK — paste full service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project"}'

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS="https://admin-viralbridgge-new.vercel.app,http://localhost:3000,http://localhost:3002"

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=""
