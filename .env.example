# ─── Neon PostgreSQL (production + Vercel) ───────────────────────────────────
# Runtime (Vercel): pooled connection (host contains "-pooler") — better for serverless.
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Migrations: direct connection (no "-pooler"). Optional locally; Vercel build auto-derives from DATABASE_URL if omitted.
DIRECT_DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Local PostgreSQL (optional, for dev only) ───────────────────────────────
# DATABASE_URL="postgresql://postgres:PASSWORD@localhost:5432/viralbridgge?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# ─── File uploads (deliverables: reels, stories, images) ─────────────────────
# Option A — Cloudinary FREE tier (recommended for Vercel; no credit card for basic use)
# Sign up: https://cloudinary.com/users/register/free
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Option B — Firebase Storage (requires Firebase Blaze billing for most projects; free quota inside)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project",...}'
FIREBASE_STORAGE_BUCKET="your-project-id.firebasestorage.app"

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS="https://admin-viralbridgge-new.vercel.app,http://localhost:3000,http://localhost:3002"

# ─── Frontend / App URL (team invitation accept links) ───────────────────────
APP_URL="https://admin-viralbridgge-new.vercel.app"

# ─── Resend (transactional + broadcast emails) ───────────────────────────────
# 1. Create account at https://resend.com
# 2. Add and verify your domain at https://resend.com/domains
# 3. Create API key at https://resend.com/api-keys
# 4. Set both vars on Vercel (backend project) → Environment Variables → Redeploy
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="ViralBridge <notifications@yourdomain.com>"
# Must match your verified Resend domain. Unverified senders will fail silently or error.

# ─── Razorpay (wallet top-ups) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Web API key from Firebase Console → Project settings → General (starts with AIza)
FIREBASE_WEB_API_KEY="AIzaSy..."

# ─── Escrow / Payments ────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=10
DELIVERABLE_MAX_UPLOAD_MB=100
# Public base URL for locally stored uploads (local dev only)
# API_PUBLIC_URL="http://localhost:4000"
# Set to true to disable the 7-day auto-release scheduler
# DISABLE_ESCROW_AUTO_RELEASE=true

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=""

# ─── Re-engagement & campaign prompt (optional testing) ───────────────────────
# RE_ENGAGEMENT_TEST_MODE=true
# CAMPAIGN_PROMPT_TEST_MODE=true
# DISABLE_RE_ENGAGEMENT=true

# ─── Vercel build migrations (Neon) ───────────────────────────────────────────
# Use non-pooler URL for migrate deploy (avoids P1002 advisory lock on pooler).
# DIRECT_DATABASE_URL="postgresql://...@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
# Or skip migrations during Vercel build (run locally: npm run prisma:migrate)
# SKIP_MIGRATE_ON_BUILD=1
