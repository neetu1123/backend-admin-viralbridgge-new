# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/viralbridge?schema=public"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret-min-32-chars"

# Firebase Admin SDK — paste full service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"...","universe_domain":"googleapis.com"}'

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,https://your-frontend.vercel.app"

# ─── Redis (optional — BullMQ background jobs) ────────────────────────────────
# Leave empty to disable Redis/BullMQ (recommended for Vercel unless using Upstash)
REDIS_URL=""

# ─── Vercel (auto-set by platform) ────────────────────────────────────────────
# VERCEL=1
